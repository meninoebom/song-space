# Song Space local environment — copy to backend/.env and fill in.
#   cp backend/.env.example backend/.env
# Standard dotenv only: plain KEY=value, no `export`, no quotes, no shell substitution.
# backend/.env is gitignored and is the single local cache read by BOTH the
# FastAPI server (via pydantic) and scripts/ingest_song.py (via load_backend_env()).

# Replicate API token — required to PROCESS new songs (Demucs + allin1).
# Get one at https://replicate.com/account/api-tokens. Library playback needs none.
REPLICATE_API_TOKEN=r8_your_token_here

# Shared-secret gate on POST /api/process (sent as the X-API-Key header).
# Invent it yourself: `openssl rand -hex 32`. The SAME value must be set here,
# in Railway (production), and be present when running scripts/ingest_song.py.
# If unset, the endpoint fails closed (503) — required to process songs.
PROCESS_API_KEY=generate_with_openssl_rand_hex_32

# Where the curated library lives, relative to backend/. Leave as-is for local dev.
LIBRARY_DIR=../library

# Base URL scripts/ingest_song.py posts to. Defaults to localhost; set only when
# ingesting against a deployed instance.
SONGSPACE_API_URL=http://localhost:8000
